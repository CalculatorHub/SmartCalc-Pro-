rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "webistehosting@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Feedback collection
    match /feedback/{feedbackId} {
      function isValidFeedback(data) {
        return data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
               data.type is string && data.type in ['Bug', 'UI/UX', 'Improvement', 'Suggestion'] &&
               data.rating is number && data.rating >= 1 && data.rating <= 5 &&
               data.createdAt == request.time &&
               (data.get('userId', '') is string) &&
               (data.get('browser', '') is string) &&
               (data.get('os', '') is string);
      }

      allow create: if isValidId(feedbackId) && isValidFeedback(incoming());
      
      allow read, list, delete, update: if isAdmin();
    }

    // Test connection path
    match /test/connection {
      allow get: if true;
    }
  }
}
